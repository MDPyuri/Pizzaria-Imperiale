generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model endereco {
  idEndereco  Int      @id @default(autoincrement())
  logradouro  String
  numero      String
  bairro      String
  cep         String
  complemento String?
  pontoRef    String?
  pedido      pedido[]
}

model itemproduto {
  idItemProduto     Int     @id @default(autoincrement())
  quantidade        Int
  preco             Decimal @db.Decimal(10, 2)
  observacao        String?
  Produto_idProduto Int
  Pedido_idPedido   Int
  pedido            pedido  @relation(fields: [Pedido_idPedido], references: [idPedido], map: "ItemProduto_Pedido_idPedido_fkey")
  produto           produto @relation(fields: [Produto_idProduto], references: [idProduto], map: "ItemProduto_Produto_idProduto_fkey")

  @@index([Pedido_idPedido], map: "ItemProduto_Pedido_idPedido_fkey")
  @@index([Produto_idProduto], map: "ItemProduto_Produto_idProduto_fkey")
}

model pagamento {
  idPagamento Int      @id @default(autoincrement())
  tipo        String
  pago        Boolean
  pedido      pedido[]
}

model pedido {
  idPedido              Int           @id @default(autoincrement())
  data                  DateTime
  valor                 Decimal       @db.Decimal(10, 2)
  Usuario_idUsuario     Int
  Endereco_idEndereco   Int?
  Pagamento_idpagamento Int?
  itemproduto           itemproduto[]
  endereco              endereco?     @relation(fields: [Endereco_idEndereco], references: [idEndereco], map: "Pedido_Endereco_idEndereco_fkey")
  pagamento             pagamento?    @relation(fields: [Pagamento_idpagamento], references: [idPagamento], map: "Pedido_Pagamento_idpagamento_fkey")
  usuario               usuario       @relation(fields: [Usuario_idUsuario], references: [idUsuario], map: "Pedido_Usuario_idUsuario_fkey")

  @@index([Endereco_idEndereco], map: "Pedido_Endereco_idEndereco_fkey")
  @@index([Pagamento_idpagamento], map: "Pedido_Pagamento_idpagamento_fkey")
  @@index([Usuario_idUsuario], map: "Pedido_Usuario_idUsuario_fkey")
}

model produto {
  idProduto   Int           @id @default(autoincrement())
  nome        String
  preco       Decimal       @db.Decimal(5, 2)
  descricao   String?
  imagem      String?
  itemproduto itemproduto[]
}

model reserva {
  idReserva         Int      @id @default(autoincrement())
  data              DateTime
  preferencia       String?
  telefone          String?
  qtdpessoas        Int
  Usuario_idUsuario Int
  usuario           usuario  @relation(fields: [Usuario_idUsuario], references: [idUsuario], map: "Reserva_Usuario_idUsuario_fkey")

  @@index([Usuario_idUsuario], map: "Reserva_Usuario_idUsuario_fkey")
}

model usuario {
  idUsuario Int       @id @default(autoincrement())
  nome      String
  telefone  String
  cpf       String    @unique(map: "Usuario_cpf_key")
  email     String    @unique(map: "Usuario_email_key")
  senha     String
  pedido    pedido[]
  reserva   reserva[]
}
